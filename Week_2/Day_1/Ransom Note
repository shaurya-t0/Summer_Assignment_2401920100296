class Solution {
public:
    bool canConstruct(string ransomNote, string magazine) {
        int freq[26]={0};
        for(int i=0 ; i < ransomNote.length() ; i++){
            freq[ransomNote[i]- 'a']++;
        }
        for(int j=0 ; j < magazine.length() ; j++){
            freq[magazine[j] - 'a']--;
        }
        for(int k=0 ;k<26;k++){
            if(freq[k]>0){
                return false;
            }
        }
        return true;
    }
};
