class Solution {
public:
    int maxArea(vector<int>& height) {
        int s = 0;
        int e = height.size() - 1;
        int ans = 0;
        while ( s < e){
            int base = e - s;
            int h = min(height[s] , height[e]);
            int amount = base * h;
            ans = max (ans , amount);
            if(height[s] < height [e]){
                s++;
            }
            else{
                e--;
            }
        }
        return ans;

    }
};
